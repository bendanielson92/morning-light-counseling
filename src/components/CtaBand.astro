---
interface Props {
  heading?: string;
  body?: string;
}
const {
  heading = 'Ready when you are',
  body = 'Reaching out takes two minutes. I respond within two business days, and a brief phone call comes before any commitment.',
} = Astro.props;
---

<section class="bg-forest-700 text-cream">
  <div class="mx-auto flex max-w-4xl flex-col items-center gap-6 px-4 py-14 text-center sm:px-6">
    <h2 class="font-display text-3xl sm:text-4xl">{heading}</h2>
    <p class="max-w-xl text-lg text-forest-100">{body}</p>
    <div class="flex flex-wrap justify-center gap-4">
      <a href="/contact" class="btn-gold">Request an Appointment</a>
      <a href="/what-to-expect" class="btn-outline-light">See how it works</a>
    </div>
  </div>
</section>
