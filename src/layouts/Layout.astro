---
import '@fontsource-variable/playfair-display';
import '@fontsource-variable/source-sans-3';
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import settings from '../content/singletons/settings.json';

interface Props {
  title: string;
  description: string;
  noindex?: boolean;
}

const { title, description, noindex = false } = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site);
const ogImage = new URL('/images/brand/logo.png', Astro.site);

const businessSchema = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  additionalType: 'https://schema.org/MedicalBusiness',
  name: 'Morning Light Counseling',
  description:
    'Faith-based counseling for men in Manheim, PA and online across Pennsylvania.',
  url: Astro.site?.toString(),
  telephone: settings.phone,
  email: settings.email,
  image: ogImage.toString(),
  priceRange: '$125 per session',
  address: {
    '@type': 'PostalAddress',
    streetAddress: settings.addressStreet,
    addressLocality: 'Manheim',
    addressRegion: 'PA',
    postalCode: '17545',
    addressCountry: 'US',
  },
  areaServed: 'Pennsylvania',
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/png" href="/images/brand/logo.png" />
    <link rel="apple-touch-icon" href="/images/brand/logo.png" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    {noindex && <meta name="robots" content="noindex" />}
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:site_name" content="Morning Light Counseling" />
    <meta name="twitter:card" content="summary" />
    <script type="application/ld+json" set:html={JSON.stringify(businessSchema)} />
  </head>
  <body>
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-50 focus:rounded-md focus:bg-forest-700 focus:px-4 focus:py-2 focus:text-cream"
    >
      Skip to main content
    </a>
    <Header />
    <main id="main">
      <slot />
    </main>
    <Footer />
  </body>
</html>
