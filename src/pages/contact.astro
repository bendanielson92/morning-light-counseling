---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
import settings from '../content/singletons/settings.json';

const reasons = [
  'General question',
  'Anxiety or stress',
  'Depression or low motivation',
  'Anger or resentment',
  'A habit I can’t put down',
  'Marriage or relationship strain',
  'A major life change',
  'I’d rather explain by phone',
];

const referralSources = [
  'Google search',
  'Word of mouth',
  'Doctor or provider referral',
  'Church or pastoral referral',
  'Psychology Today',
  'Other',
];
---

<Layout
  title="Contact | Morning Light Counseling — Manheim, PA"
  description="Request an appointment with Morning Light Counseling. A short form, a reply within two business days, and a phone call before your first session."
>
  <PageHero
    title="Contact Us"
    tagline="Complete the form below and someone will respond within 2 business days. Prefer to talk? Call anytime."
  />

  <div class="mx-auto grid max-w-6xl gap-12 px-4 pb-16 sm:px-6 lg:grid-cols-[3fr_2fr]">
    <section aria-labelledby="form-heading">
      <h2 id="form-heading" class="sr-only">New client inquiry form</h2>

      <p
        id="form-error"
        role="alert"
        hidden
        class="mb-6 rounded-md border border-gold-500 bg-gold-100 px-4 py-3 font-medium"
      >
        Something was missing or didn't look right — please check the fields and try again. If it keeps happening,
        just call {settings.phone}.
      </p>
      <script>
        if (new URLSearchParams(location.search).has('error')) {
          document.getElementById('form-error')?.removeAttribute('hidden');
        }
      </script>

      <form method="POST" action="/api/contact" class="grid gap-5 rounded-lg border border-gold-200 bg-white p-6 shadow-sm sm:p-8">
        <div class="grid gap-5 sm:grid-cols-2">
          <div>
            <label for="name" class="mb-1 block font-semibold">Name <span aria-hidden="true" class="text-gold-700">*</span></label>
            <input type="text" id="name" name="name" required autocomplete="name"
              class="w-full rounded-md border border-forest-300 bg-cream px-3 py-2.5" />
          </div>
          <div>
            <label for="phone" class="mb-1 block font-semibold">Phone <span aria-hidden="true" class="text-gold-700">*</span></label>
            <input type="tel" id="phone" name="phone" required autocomplete="tel"
              class="w-full rounded-md border border-forest-300 bg-cream px-3 py-2.5" />
          </div>
        </div>

        <div>
          <label for="email" class="mb-1 block font-semibold">Email <span aria-hidden="true" class="text-gold-700">*</span></label>
          <input type="email" id="email" name="email" required autocomplete="email"
            class="w-full rounded-md border border-forest-300 bg-cream px-3 py-2.5" />
        </div>

        <fieldset>
          <legend class="mb-1 font-semibold">Okay to leave a voicemail? <span aria-hidden="true" class="text-gold-700">*</span></legend>
          <div class="flex gap-6">
            <label class="flex items-center gap-2">
              <input type="radio" name="voicemail" value="Yes" required class="accent-forest-600" /> Yes
            </label>
            <label class="flex items-center gap-2">
              <input type="radio" name="voicemail" value="No" class="accent-forest-600" /> No
            </label>
          </div>
        </fieldset>

        <fieldset>
          <legend class="mb-1 font-semibold">How do you plan to pay? <span aria-hidden="true" class="text-gold-700">*</span></legend>
          <div class="flex flex-wrap gap-x-6 gap-y-2">
            <label class="flex items-center gap-2">
              <input type="radio" name="payment" value="Insurance" required class="accent-forest-600" /> Insurance
            </label>
            <label class="flex items-center gap-2">
              <input type="radio" name="payment" value="EAP" class="accent-forest-600" /> Employee assistance program (EAP)
            </label>
            <label class="flex items-center gap-2">
              <input type="radio" name="payment" value="Self-pay" class="accent-forest-600" /> Self-pay
            </label>
          </div>
        </fieldset>

        <div>
          <label for="reason" class="mb-1 block font-semibold">Reason for visit <span aria-hidden="true" class="text-gold-700">*</span></label>
          <select id="reason" name="reason" required class="w-full rounded-md border border-forest-300 bg-cream px-3 py-2.5">
            <option value="" selected disabled>Choose the closest fit…</option>
            {reasons.map((r) => <option value={r}>{r}</option>)}
          </select>
          <p class="mt-2 text-sm text-ink/80">
            A general category is all that's needed here — please don't include detailed health information in this
            form. We'll cover the specifics privately, by phone.
          </p>
        </div>

        <div>
          <label for="referral" class="mb-1 block font-semibold">How did you hear about Morning Light Counseling?</label>
          <select id="referral" name="referral" class="w-full rounded-md border border-forest-300 bg-cream px-3 py-2.5">
            <option value="" selected disabled>Choose one…</option>
            {referralSources.map((r) => <option value={r}>{r}</option>)}
          </select>
        </div>

        <div class="absolute -left-[9999px]" aria-hidden="true">
          <label for="company">Leave this field empty</label>
          <input type="text" id="company" name="company" tabindex="-1" autocomplete="off" />
        </div>

        <button type="submit" class="btn-gold mt-2 text-lg">Send Inquiry</button>

        <p class="text-sm text-ink/80">
          This form is for scheduling and general questions — it isn't monitored for emergencies. If you're in
          crisis, call or text <a href="tel:988" class="font-semibold text-gold-700 underline">988</a> or call
          <a href="tel:911" class="font-semibold text-gold-700 underline">911</a>. Submissions are sent securely and
          handled per our <a href="/privacy-policy" class="text-gold-700 underline">privacy policy</a>.
        </p>
      </form>
    </section>

    <aside class="space-y-8">
      <section class="rounded-lg border border-forest-200 bg-forest-50 p-6">
        <h2 class="font-display text-xl font-semibold text-forest-800">Already a client?</h2>
        <p class="mt-2">Schedule, reschedule, and manage paperwork through the secure client portal.</p>
        <a href={settings.carepatronUrl} target="_blank" rel="noopener" class="btn-forest mt-4">
          Open Client Portal<span class="sr-only"> (opens in a new tab)</span>
          <span aria-hidden="true">↗</span>
        </a>
      </section>

      <section>
        <h2 class="font-display text-xl font-semibold text-forest-800">Contact directly</h2>
        <address class="mt-3 space-y-2 not-italic">
          <p>
            <a href={`tel:${settings.phone.replace(/[^\d+]/g, '')}`} class="font-semibold text-gold-700 underline underline-offset-2">{settings.phone}</a>
          </p>
          <p>
            <a href={`mailto:${settings.email}`} class="break-all text-gold-700 underline underline-offset-2">{settings.email}</a>
          </p>
          <p>
            {settings.addressStreet}<br />
            {settings.addressCity}
          </p>
          {settings.officeHours && <p>{settings.officeHours}</p>}
        </address>
        <a
          href={`https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(`Morning Light Counseling, ${settings.addressStreet}, ${settings.addressCity}`)}`}
          target="_blank"
          rel="noopener"
          class="mt-3 inline-block text-gold-700 underline underline-offset-2"
        >
          Get directions<span class="sr-only"> (opens in a new tab)</span> <span aria-hidden="true">↗</span>
        </a>
      </section>

      <section class="rounded-lg border border-gold-200 bg-gold-50 p-6">
        <h2 class="font-display text-xl font-semibold text-forest-800">What happens next?</h2>
        <p class="mt-2">
          I reply within two business days, send you intake paperwork through the secure portal, and we talk briefly
          by phone before your first session. <a href="/what-to-expect" class="text-gold-700 underline underline-offset-2">The full rundown is here.</a>
        </p>
      </section>
    </aside>
  </div>
</Layout>
