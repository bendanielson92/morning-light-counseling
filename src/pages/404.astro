---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Page Not Found | Morning Light Counseling"
  description="That page doesn't exist."
  noindex
>
  <section class="mx-auto max-w-2xl px-4 py-24 text-center sm:px-6">
    <img src="/images/brand/logo.png" alt="" width="96" height="96" class="mx-auto h-24 w-24 opacity-80 mix-blend-multiply" />
    <h1 class="mt-6 font-display text-4xl font-bold text-ink">This page took the day off</h1>
    <p class="mt-4 text-lg">
      The page you're looking for doesn't exist — it may have moved when the site was rebuilt.
    </p>
    <div class="mt-8 flex flex-wrap justify-center gap-4">
      <a href="/" class="btn-gold">Back to home</a>
      <a href="/contact" class="btn-outline">Contact</a>
    </div>
  </section>
</Layout>
