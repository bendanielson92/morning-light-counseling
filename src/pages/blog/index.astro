---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import PageHero from '../../components/PageHero.astro';
import CtaBand from '../../components/CtaBand.astro';

const posts = (await getCollection('posts', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const formatDate = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
---

<Layout
  title="Blog | Morning Light Counseling"
  description="Short, straight-shooting articles on men's mental health, faith, and the work of change — from Morning Light Counseling in Manheim, PA."
  noindex={posts.length === 0}
>
  <PageHero title="From the Desk" tagline="Short, useful, and written for men — no fluff, no jargon." />

  <section class="mx-auto max-w-3xl px-4 pb-16 sm:px-6">
    {
      posts.length === 0 ? (
        <p class="rounded-lg border border-gold-200 bg-gold-50 p-8 text-center text-lg">
          Articles are coming. In the meantime, <a href="/counseling" class="text-gold-700 underline underline-offset-2">the counseling pages</a> are the best place to start.
        </p>
      ) : (
        <ul class="space-y-8">
          {posts.map((post) => (
            <li class="rounded-lg border border-gold-200 bg-white p-7 shadow-sm">
              <p class="text-sm font-semibold uppercase tracking-wide text-gold-700">
                {formatDate(post.data.pubDate)}
              </p>
              <h2 class="mt-2 font-display text-2xl font-semibold text-forest-800">
                <a href={`/blog/${post.id}`} class="hover:text-gold-700 hover:underline">
                  {post.data.title}
                </a>
              </h2>
              <p class="mt-3">{post.data.description}</p>
              <a href={`/blog/${post.id}`} class="mt-4 inline-block font-semibold text-gold-700">
                Read more <span aria-hidden="true">→</span>
                <span class="sr-only">: {post.data.title}</span>
              </a>
            </li>
          ))}
        </ul>
      )
    }
  </section>

  <CtaBand />
</Layout>
