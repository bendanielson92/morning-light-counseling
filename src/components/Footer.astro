---
import { getCollection } from 'astro:content';
import settings from '../content/singletons/settings.json';

const services = (await getCollection('services')).sort(
  (a, b) => a.data.order - b.data.order
);
const year = new Date().getFullYear();
---

<footer class="bg-forest-800 text-cream">
  <div class="mx-auto grid max-w-6xl gap-10 px-4 py-12 sm:px-6 md:grid-cols-2 lg:grid-cols-4">
    <div>
      <p class="font-display text-xl font-bold">Morning Light Counseling</p>
      <p class="mt-3 text-forest-100">
        Faith-based counseling for men — hope-focused, honest, and grounded in a Biblical framework.
      </p>
      <p class="mt-3 text-forest-100">{settings.telehealthNote}</p>
    </div>

    <nav aria-label="Counseling services">
      <p class="font-semibold uppercase tracking-wide text-gold-300">
        <a href="/counseling" class="hover:text-gold-200 hover:underline">How I Help</a>
      </p>
      <ul class="mt-3 space-y-2">
        {
          services.map((s) => (
            <li>
              <a href={`/counseling/${s.id}`} class="text-forest-100 hover:text-cream hover:underline">
                {s.data.navTitle}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>

    <nav aria-label="Practice pages">
      <p class="font-semibold uppercase tracking-wide text-gold-300">The Practice</p>
      <ul class="mt-3 space-y-2">
        <li><a href="/mens-counseling" class="text-forest-100 hover:text-cream hover:underline">Men's Counseling</a></li>
        <li><a href="/about" class="text-forest-100 hover:text-cream hover:underline">About Billy</a></li>
        <li><a href="/what-to-expect" class="text-forest-100 hover:text-cream hover:underline">What to Expect</a></li>
        <li><a href="/contact" class="text-forest-100 hover:text-cream hover:underline">Contact</a></li>
        <li>
          <a href={settings.carepatronUrl} target="_blank" rel="noopener" class="text-forest-100 hover:text-cream hover:underline">
            Active Clients<span class="sr-only"> (opens the scheduling portal in a new tab)</span> <span aria-hidden="true">↗</span>
          </a>
        </li>
      </ul>
    </nav>

    <div>
      <p class="font-semibold uppercase tracking-wide text-gold-300">Contact</p>
      <address class="mt-3 space-y-2 not-italic text-forest-100">
        <p>{settings.addressStreet}<br />{settings.addressCity}</p>
        <p>
          <a href={`tel:${settings.phone.replace(/[^\d+]/g, '')}`} class="hover:text-cream hover:underline">{settings.phone}</a>
        </p>
        <p>
          <a href={`mailto:${settings.email}`} class="break-all hover:text-cream hover:underline">{settings.email}</a>
        </p>
        {settings.officeHours && <p>{settings.officeHours}</p>}
      </address>
    </div>
  </div>

  <div class="bg-forest-900">
    <div class="mx-auto max-w-6xl px-4 py-5 sm:px-6">
      <p class="text-center text-forest-100">
        <strong class="text-cream">In crisis?</strong> This website is not monitored for emergencies. If you or someone
        you know is in danger, call or text <a href="tel:988" class="font-semibold text-gold-300 underline">988</a>
        (Suicide &amp; Crisis Lifeline) or call <a href="tel:911" class="font-semibold text-gold-300 underline">911</a>.
      </p>
    </div>
  </div>

  <div class="border-t border-forest-700 bg-forest-900">
    <div class="mx-auto flex max-w-6xl flex-col items-center gap-3 px-4 py-6 text-sm text-forest-200 sm:px-6">
      <p class="text-center">{settings.licenseLine}</p>
      <nav aria-label="Legal" class="flex flex-wrap justify-center gap-x-6 gap-y-2">
        <a href="/privacy-policy" class="hover:text-cream hover:underline">Privacy Policy</a>
        <a href="/good-faith-estimate" class="hover:text-cream hover:underline">Good Faith Estimate</a>
        <a href="/accessibility" class="hover:text-cream hover:underline">Accessibility</a>
      </nav>
      <p>&copy; {year} Morning Light Counseling Services. All rights reserved.</p>
    </div>
  </div>
</footer>
