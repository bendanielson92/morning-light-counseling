---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import PageHero from '../../components/PageHero.astro';
import CtaBand from '../../components/CtaBand.astro';

const services = (await getCollection('services')).sort(
  (a, b) => a.data.order - b.data.order
);
---

<Layout
  title="How I Help | Morning Light Counseling — Manheim, PA"
  description="Counseling for men dealing with anxiety, depression, anger, compulsive habits, marriage strain, and major life transitions. Manheim, PA and online across Pennsylvania."
>
  <PageHero
    title="How I Help"
    tagline="These are the struggles that most often bring men through the door. If yours isn't listed, reach out anyway — this list is where we start, not where we stop."
  />

  <section class="mx-auto max-w-6xl px-4 pb-16 sm:px-6">
    <div class="grid gap-6 sm:grid-cols-2">
      {
        services.map((s) => (
          <a
            href={`/counseling/${s.id}`}
            class="group flex flex-col rounded-lg border border-gold-200 bg-white p-7 shadow-sm transition-shadow hover:border-gold-400 hover:shadow-md"
          >
            <h2 class="font-display text-2xl font-semibold text-forest-800 group-hover:text-gold-700">
              {s.data.navTitle}
            </h2>
            <p class="mt-3 flex-1 text-lg text-ink/90">{s.data.summary}</p>
            <span class="mt-5 font-semibold text-gold-700">
              Learn more <span aria-hidden="true">→</span>
            </span>
          </a>
        ))
      }
    </div>
  </section>

  <CtaBand />
</Layout>
