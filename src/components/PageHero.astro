---
interface Props {
  title: string;
  tagline?: string;
}
const { title, tagline } = Astro.props;
---

<section class="bg-gradient-to-b from-gold-100 to-cream">
  <div class="mx-auto max-w-4xl px-4 pb-10 pt-14 sm:px-6 sm:pb-14 sm:pt-20">
    <h1 class="font-display text-4xl font-bold text-ink sm:text-5xl">{title}</h1>
    {tagline && <p class="mt-5 max-w-2xl text-xl text-forest-800">{tagline}</p>}
  </div>
</section>
