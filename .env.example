# --- Contact form (production) ---
# Create a free account at https://resend.com, verify the domain, and paste the API key.
RESEND_API_KEY=
# Where inquiries are sent. Defaults to the practice email in site settings if unset.
CONTACT_TO_EMAIL=billy@morninglightcounselingservices.com
# Must be on a Resend-verified domain (e.g. inquiries@morninglightcounselingservices.com).
# For pre-launch testing you can use onboarding@resend.dev
CONTACT_FROM_EMAIL=onboarding@resend.dev

# --- Keystatic (production only — leave all unset for local dev) ---
# Setting this switches the control panel from local mode to GitHub mode.
# e.g. bendanielson/morning-light-site
PUBLIC_KEYSTATIC_GITHUB_REPO=
KEYSTATIC_GITHUB_CLIENT_ID=
KEYSTATIC_GITHUB_CLIENT_SECRET=
KEYSTATIC_SECRET=
