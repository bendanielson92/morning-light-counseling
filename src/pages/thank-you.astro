---
import Layout from '../layouts/Layout.astro';
import settings from '../content/singletons/settings.json';
---

<Layout
  title="Thank You | Morning Light Counseling"
  description="Your inquiry has been received."
  noindex
>
  <section class="mx-auto max-w-2xl px-4 py-20 text-center sm:px-6 sm:py-28">
    <img src="/images/brand/logo.png" alt="" width="96" height="96" class="mx-auto h-24 w-24 mix-blend-multiply" />
    <h1 class="mt-6 font-display text-4xl font-bold text-ink">Thank you for reaching out.</h1>
    <p class="mt-5 text-lg">
      Someone will respond within <strong>2 business days</strong>. If your request is time-sensitive, call
      <a href={`tel:${settings.phone.replace(/[^\d+]/g, '')}`} class="font-semibold text-gold-700 underline underline-offset-2">{settings.phone}</a>.
      If this is an emergency situation, please reach out to your local county crisis intervention or contact 911.
    </p>
    <p class="mt-4 text-ink/80">
      In the meantime, <a href="/what-to-expect" class="text-gold-700 underline underline-offset-2">here's what happens next</a>.
    </p>
    <a href="/" class="btn-outline mt-8">Back to home</a>
  </section>
</Layout>
